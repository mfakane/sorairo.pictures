---
import Article from "@/components/Article.astro";
import BlogSidebar from "@/components/BlogSidebar.astro";
import { getBlogEntryPermalink } from "@/lib/blog-entry-path";
import { getExcerptHtmlFromRenderedContent } from "@/lib/content-preview";
import { render, type CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";

export interface Props {
  title: string;
  entries: readonly CollectionEntry<"blog">[];
}

const { title, entries }: Props = Astro.props;
type ArticleContent = Awaited<ReturnType<typeof render>>["Content"];

type ArticleForIndex = {
  slug: string;
  permalink: string;
  data: CollectionEntry<"blog">["data"];
  excerptHtml?: string;
  Content?: ArticleContent;
};

const articles: ArticleForIndex[] = [];

for (const entry of entries) {
  const excerptHtml = getExcerptHtmlFromRenderedContent(entry.rendered?.html);
  const permalink = getBlogEntryPermalink(entry);

  if (excerptHtml) {
    articles.push({
      slug: entry.id,
      permalink,
      data: entry.data,
      excerptHtml,
    });
    continue;
  }

  const { Content } = await render(entry);
  articles.push({
    slug: entry.id,
    permalink,
    data: entry.data,
    Content,
  });
}

articles.sort((x, y) =>
  (x.data.updated ?? x.data.date) < (y.data.updated ?? y.data.date) ? 1 : -1,
);
---

<Layout title={title}>
  <main>
    {
      articles.map((article) => (
        <Article
          date={article.data.date}
          updated={article.data.updated}
          permalink={article.permalink}
          category={article.data.category}
          tags={article.data.tags ?? []}
        >
          <h1 slot="title">
            <a href={article.permalink}>{article.data.title}</a>
          </h1>
          {article.excerptHtml ? (
            <>
              <Fragment set:html={article.excerptHtml} />
              <a class="more" href={article.permalink}>
                Read more
              </a>
            </>
          ) : (
            article.Content && <article.Content />
          )}
        </Article>
      ))
    }
    <slot />
  </main>
  <aside>
    <BlogSidebar />
  </aside>
</Layout>
