---
interface Item {
  text: string;
  slug?: string;
  children: readonly Item[];
}

export interface Props {
  items: readonly Item[];
}

const { items }: Props = Astro.props;
---

{
  items.length > 0 && (
    <ol>
      {items.map((x) => (
        <li>
          {x.slug ? <a href={`#${x.slug}`}>{x.text}</a> : x.text}
          {x.children.length > 0 && <Astro.self items={x.children} />}
        </li>
      ))}
    </ol>
  )
}
