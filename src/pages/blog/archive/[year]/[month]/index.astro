---
import Pager from "@/components/Pager.astro";
import BlogEntryIndexLayout from "@/layouts/BlogEntryIndexLayout.astro";
import { getArchivePermalink } from "@/lib/blog-entry-path";
import { getMonthIndexPaths } from "@/lib/paginate-blog";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

export const getStaticPaths = (async () =>
  getMonthIndexPaths()) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<meta name="robots" content="noindex" />

{
  (Astro.props as Props).entries && (
    <BlogEntryIndexLayout
      title={`${(Astro.props as Props).year}-${(Astro.props as Props).month}`}
      entries={(Astro.props as Props).entries}
    >
      <Pager
        currentPage={(Astro.props as Props).currentPage}
        lastPage={(Astro.props as Props).lastPage}
        urlPrefix={getArchivePermalink((Astro.props as Props).year, (Astro.props as Props).month)}
      />
    </BlogEntryIndexLayout>
  )
}
