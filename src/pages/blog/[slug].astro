---
import BlogEntryLayout from "@/layouts/BlogEntryLayout.astro";
import { getBlogEntryRouteParams } from "@/lib/blog-entry-path";
import { type CollectionEntry, getCollection } from "astro:content";

type StaticPath = {
  params: { slug: string };
  props: Props;
};

export async function getStaticPaths(): Promise<StaticPath[]> {
  const blogEntries = await getCollection("blog");

  return blogEntries.map((entry) => {
    const params = getBlogEntryRouteParams(entry);
    return {
      params,
      props: { entry } as Props,
    };
  });
}

export interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry }: Props = Astro.props;
---

{entry && <BlogEntryLayout entry={entry} />}
