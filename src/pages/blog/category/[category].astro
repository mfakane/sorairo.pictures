---
import Pager from "@/components/Pager.astro";
import BlogEntryIndexLayout from "@/layouts/BlogEntryIndexLayout.astro";
import { getCategoryIndexPaths } from "@/lib/paginate-blog";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

export const getStaticPaths = (async () =>
  getCategoryIndexPaths()) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<meta name="robots" content="noindex" />

{
  (Astro.props as Props).entries && (
    <BlogEntryIndexLayout
      title={`${(Astro.props as Props).category}`}
      entries={(Astro.props as Props).entries}
    >
      <Pager
        currentPage={(Astro.props as Props).currentPage}
        lastPage={(Astro.props as Props).lastPage}
        urlPrefix={`/blog/category/${(Astro.props as Props).category}`}
      />
    </BlogEntryIndexLayout>
  )
}
