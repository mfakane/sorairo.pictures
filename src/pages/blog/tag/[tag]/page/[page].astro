---
import Pager from "@/components/Pager.astro";
import BlogEntryIndexLayout from "@/layouts/BlogEntryIndexLayout.astro";
import { getTagPermalink } from "@/lib/blog-entry-path";
import { getTagPagePaths } from "@/lib/paginate-blog";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

export const getStaticPaths = (async ({ paginate }) =>
  getTagPagePaths(paginate)) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<meta name="robots" content="noindex" />

{
  (Astro.props as Props).page.data && (
    <BlogEntryIndexLayout
      title={`#${(Astro.props as Props).tag}`}
      entries={(Astro.props as Props).page.data}
    >
      <Pager
        currentPage={(Astro.props as Props).page.currentPage}
        lastPage={(Astro.props as Props).page.lastPage}
        urlPrefix={getTagPermalink((Astro.props as Props).tag)}
      />
    </BlogEntryIndexLayout>
  )
}
