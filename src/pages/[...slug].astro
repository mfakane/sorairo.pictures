---
import SiteEntryIndexLayout from "@/layouts/SiteEntryIndexLayout.astro";
import SiteEntryLayout from "@/layouts/SiteEntryLayout.astro";
import { type CollectionEntry, getCollection } from "astro:content";

type StaticPath = { params: { slug: string }; props: Props };

export async function getStaticPaths(): Promise<StaticPath[]> {
  const siteEntries = await getCollection("site");
  const siteCategories = [
    ...new Set(
      siteEntries
        .map((entry) => {
          const lastSlash = entry.id.lastIndexOf("/");
          return lastSlash >= 0 ? entry.id.slice(0, lastSlash) : null;
        })
        .filter((x) => x !== null),
    ),
  ];

  return siteEntries
    .map((entry) => ({
      params: { slug: entry.id as string },
      props: { entry } as Props,
    }))
    .concat(
      siteCategories.map((category) => ({
        params: { slug: category as string },
        props: {
          category,
          entries: siteEntries.filter((entry) =>
            entry.id.startsWith(category + "/"),
          ),
        } as Props,
      })),
    );
}

export interface Props {
  category?: string;
  entry?: CollectionEntry<"site">;
  entries?: readonly CollectionEntry<"site">[];
}

const { category, entry, entries }: Props = Astro.props;
---

{entry && <SiteEntryLayout entry={entry} />}
{
  category && entries && (
    <SiteEntryIndexLayout category={category} entries={entries} />
  )
}
